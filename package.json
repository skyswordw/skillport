{
  "name": "@skyswordw/skillport",
  "version": "0.1.0",
  "description": "Static cross-agent portability linter for agent skills: will your SKILL.md work on Claude Code, Codex, and Cursor? Catch what breaks before you publish.",
  "type": "module",
  "bin": {
    "skillport": "./dist/cli.js"
  },
  "files": [
    "dist/*.js",
    "dist/*.d.ts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "assets/demo.svg"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:test": "tsc -p tsconfig.test.json",
    "check": "tsc -p tsconfig.test.json --noEmit",
    "prepare": "npm run build",
    "prepublishOnly": "npm run check && npm test",
    "start": "node dist/cli.js",
    "demo": "node dist/cli.js fixtures --target claude-code,codex,cursor",
    "demo:svg": "node scripts/gen-demo.mjs",
    "test": "npm run build:test && node --test 'dist-test/**/*.test.js'"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "agent-skills",
    "skill",
    "claude-code",
    "codex",
    "cursor",
    "linter",
    "compatibility",
    "portability",
    "ci",
    "cli"
  ],
  "author": "skywalker",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/skyswordw/skillport.git"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "typescript": "~6.0.2"
  },
  "engines": {
    "node": ">=20"
  }
}
